<LoginScreen>:
    canvas.before:
        Color:
            rgba: 0.96, 0.96, 0.97, 1
        Rectangle:
            size: self.size
            pos: self.pos
    BoxLayout:
        orientation: 'vertical'
        spacing: 30
        padding: [80, 120]
        size_hint: (0.5, 0.6)
        pos_hint: {'center_x': 0.5, 'center_y': 0.5}

        Label:
            text: 'Clinician Login'
            font_size: 32
            bold: True
            color: 0.1, 0.1, 0.1, 1
            size_hint_y: None
            height: 60

        TextInput:
            id: clinician_name_input
            hint_text: 'Enter your name'
            multiline: False
            font_size: 22
            size_hint_y: None
            height: 50
            padding: [10, 10]
            disabled: False
            readonly: False

        Button:
            text: 'Start New Medical Record'
            font_size: 22
            size_hint_y: None
            height: 50
            background_color: 0.2, 0.4, 0.2, 1
            color: 1, 1, 1, 1
            on_press: root.start_session(clinician_name_input.text)
            canvas.before:
                Color:
                    rgba: 0.2, 0.4, 0.2, 1
                RoundedRectangle:
                    size: self.size
                    pos: self.pos
                    radius: [8]
