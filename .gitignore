# Ignore environment variables

# !!!IMPORTANT - DO NOT REMOVE THIS LINE IF YOU HAVE A .env FILE. FOR SECURITY REASONS, THIS FILE SHOULD NOT BE TRACKED BY GIT.!!!
.env
key.json

